<Window x:Class="Task1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CRM" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <ListView x:Name="lvClients"
                  Grid.Column="0"
                  ItemsSource="{Binding Clients}"
                  SelectionChanged="lvClients_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ФИО" DisplayMemberBinding="{Binding FullName}" Width="150"/>
                    <GridViewColumn Header="Телефон" DisplayMemberBinding="{Binding Phone}" Width="120"/>
                    <GridViewColumn Header="Email" DisplayMemberBinding="{Binding Email}" Width="150"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock Text="ФИО"/>
            <TextBox x:Name="txtFullName"/>

            <TextBlock Text="Телефон" Margin="0,10,0,0"/>
            <TextBox x:Name="txtPhone"/>

            <TextBlock Text="Email" Margin="0,10,0,0"/>
            <TextBox x:Name="txtEmail"/>

            <TextBlock Text="История взаимодействий" Margin="0,10,0,0"/>
            <TextBox x:Name="txtHistory" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="Добавить" Width="80" Click="AddClient_Click" Margin="0,0,10,0"/>
                <Button Content="Обновить" Width="80" Click="UpdateClient_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>