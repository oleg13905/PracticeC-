<Window x:Class="Task1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CRM для бизнеса" Height="600" Width="1100">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="Клиенты">
                <MenuItem Header="_Добавить клиента (Ctrl+N)" Click="MenuAddClient_Click" InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Редактировать (Ctrl+E)" Click="MenuEditClient_Click" InputGestureText="Ctrl+E"/>
                <MenuItem Header="_Удалить (Ctrl+D)" Click="MenuDeleteClient_Click" InputGestureText="Ctrl+D"/>
            </MenuItem>
            <MenuItem Header="Помощь">
                <MenuItem Header="О программе" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <ToolBar DockPanel.Dock="Top">
            <Button Name="btnAdd" Click="BtnAdd_Click" ToolTip="Добавить клиента (Ctrl+N)">
                Добавить
            </Button>
            <Button Name="btnEdit" Click="BtnEdit_Click" ToolTip="Редактировать клиента (Ctrl+E)">
                Редактировать
            </Button>
            <Separator/>
            <Button Name="btnDelete" Click="BtnDelete_Click" ToolTip="Удалить клиента (Ctrl+D)">
                Удалить
            </Button>
        </ToolBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Клиенты" Grid.Column="0" Margin="5">
                <ListView x:Name="lvClients" ItemsSource="{Binding Clients}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="ФИО" DisplayMemberBinding="{Binding FullName}" Width="180"/>
                            <GridViewColumn Header="Телефон" DisplayMemberBinding="{Binding Phone}" Width="140"/>
                            <GridViewColumn Header="Email" DisplayMemberBinding="{Binding Email}" Width="180"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>

            <GroupBox Header="Информация о клиенте" Grid.Column="1" Margin="5">
                <StackPanel Margin="10">
                    <TextBlock Text="ФИО" FontWeight="Bold"/>
                    <TextBox x:Name="txtFullName" FontSize="14" Height="28"/>

                    <TextBlock Text="Телефон" FontWeight="Bold" Margin="0,12,0,0"/>
                    <TextBox x:Name="txtPhone" FontSize="14" Height="28"/>

                    <TextBlock Text="Email" FontWeight="Bold" Margin="0,12,0,0"/>
                    <TextBox x:Name="txtEmail" FontSize="14" Height="28"/>

                    <TextBlock Text="История взаимодействий" FontWeight="Bold" Margin="0,12,0,0"/>
                    <TextBox x:Name="txtHistory" Height="120" TextWrapping="Wrap" AcceptsReturn="True"/>

                    <TextBlock x:Name="txtStatus" Text="Выберите клиента или добавьте нового" 
                               Foreground="Gray" Margin="0,10,0,0" FontStyle="Italic"/>
                </StackPanel>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>