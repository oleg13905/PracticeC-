<Window x:Class="Task1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CRM - DataBinding Demo" Height="650" Width="1200">
    <DockPanel>
        <ToolBar DockPanel.Dock="Top">
            <Button Name="btnAdd" Content="Добавить" Click="BtnAdd_Click" Margin="5"/>
            <Button Name="btnEdit" Content="Сохранить" Click="BtnSave_Click" Margin="5"/>
            <Button Name="btnDelete" Content="Удалить" Click="BtnDelete_Click" Margin="5"/>
            <Separator/>
            <Button Name="btnClear" Content="Очистить форму" Click="BtnClear_Click" Margin="5"/>
        </ToolBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Список клиентов" Grid.Column="0" Margin="10">
                <ListView x:Name="lvClients" 
                          ItemsSource="{Binding Clients}"
                          SelectedItem="{Binding SelectedClient}"
                          Margin="5">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="ФИО" Width="200" DisplayMemberBinding="{Binding FullName}"/>
                            <GridViewColumn Header="Телефон" Width="140" DisplayMemberBinding="{Binding Phone}"/>
                            <GridViewColumn Header="Email" Width="180" DisplayMemberBinding="{Binding Email}"/>
                            <GridViewColumn Header="Тип" Width="100" DisplayMemberBinding="{Binding ClientType}"/>
                        </GridView>
                    </ListView.View>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="LightGray" Margin="2" Padding="5">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="12" Height="12" Fill="SteelBlue" Margin="0,0,8,0"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding FullName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding ClientType}" FontSize="11" Foreground="DarkBlue"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </GroupBox>

            <GroupBox Header="Редактирование клиента" Grid.Column="1" Margin="10">
                <StackPanel Margin="15">
                    <TextBlock Text="ФИО:"/>
                    <TextBox Text="{Binding SelectedClient.FullName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

                    <TextBlock Text="Телефон:" Margin="0,10,0,0"/>
                    <TextBox Text="{Binding SelectedClient.Phone, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

                    <TextBlock Text="Email:" Margin="0,10,0,0"/>
                    <TextBox Text="{Binding SelectedClient.Email, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>

                    <TextBlock Text="Тип клиента:" Margin="0,15,0,0"/>
                    <ComboBox SelectedItem="{Binding SelectedClient.ClientType, Mode=TwoWay}">
                        <ComboBoxItem Content="Обычный"/>
                        <ComboBoxItem Content="VIP"/>
                        <ComboBoxItem Content="Партнер"/>
                    </ComboBox>

                    <TextBlock Text="История:" Margin="0,15,0,0"/>
                    <TextBox Text="{Binding SelectedClient.InteractionHistory, Mode=TwoWay}" 
                             Height="100" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                    <TextBlock x:Name="txtStatus" Text="Выберите клиента" 
                               Foreground="Gray" Margin="0,10,0,0" FontStyle="Italic"/>
                </StackPanel>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>