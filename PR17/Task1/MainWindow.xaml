<Window x:Class="CrmDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CRM MVVM" Height="600" Width="1200">

    <DockPanel>
        <ToolBar DockPanel.Dock="Top">
            <Button Command="{Binding LoadCommand}" Content="🔄 Загрузить"/>
            <Separator/>
            <Button Command="{Binding AddCommand}" Content="➕ Добавить"/>
            <Button Command="{Binding SaveCommand}" Content="💾 Сохранить"/>
            <Button Command="{Binding DeleteCommand}" Content="🗑 Удалить"/>
        </ToolBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Клиенты -->
            <GroupBox Header="Клиенты" Grid.Column="0" Margin="10">
                <ListView ItemsSource="{Binding Clients}" 
                          SelectedItem="{Binding SelectedClient}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="ФИО" Width="200" DisplayMemberBinding="{Binding FullName}"/>
                            <GridViewColumn Header="Телефон" Width="140" DisplayMemberBinding="{Binding Phone}"/>
                            <GridViewColumn Header="Email" Width="180" DisplayMemberBinding="{Binding Email}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>

            <!-- Редактирование -->
            <GroupBox Header="Редактирование" Grid.Column="1" Margin="10">
                <StackPanel Margin="15">
                    <TextBlock Text="ФИО"/>
                    <TextBox Text="{Binding SelectedClient.FullName, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Телефон" Margin="0,10,0,0"/>
                    <TextBox Text="{Binding SelectedClient.Phone}"/>

                    <TextBlock Text="Email" Margin="0,10,0,0"/>
                    <TextBox Text="{Binding SelectedClient.Email}"/>

                    <ProgressBar x:Name="LoadingIndicator" 
                                 IsIndeterminate="True" Height="6"
                                 Visibility="Collapsed"
                                 Margin="0,20,0,0"/>

                    <TextBlock x:Name="txtStatus" Text="{Binding StatusMessage}" Margin="0,10"/>
                </StackPanel>
            </GroupBox>

            <!-- Сделки и уведомления -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <GroupBox Header="Уведомления" Grid.Row="0" Margin="5">
                    <ScrollViewer Height="150">
                        <TextBox Text="{Binding Notifications, Mode=OneWay}" 
                                 TextWrapping="Wrap" IsReadOnly="True"/>
                    </ScrollViewer>
                </GroupBox>

                <GroupBox Header="Сделки клиента" Grid.Row="1" Margin="5">
                    <ListView ItemsSource="{Binding Deals}" 
                              SelectedItem="{Binding SelectedDeal}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" Width="50" DisplayMemberBinding="{Binding Id}"/>
                                <GridViewColumn Header="Сумма" Width="100" DisplayMemberBinding="{Binding Amount}"/>
                                <GridViewColumn Header="Статус" Width="100" DisplayMemberBinding="{Binding Status}"/>
                                <GridViewColumn Header="Дата" Width="120" DisplayMemberBinding="{Binding Date}"/>
                                <GridViewColumn Header="Менеджер" Width="120" DisplayMemberBinding="{Binding Manager}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5">
                    <Button Content="➕ Добавить сделку" Command="{Binding AddDealCommand}" Margin="2"/>
                    <Button Content="📨 Отправить уведомление" Command="{Binding SendNotificationCommand}" Margin="2"/>
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>