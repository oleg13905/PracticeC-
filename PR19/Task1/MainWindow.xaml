<!-- MainWindow.xaml -->
<Window x:Class="CRMApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CRM Система" Height="550" Width="850"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Загрузить" Width="100" Height="35" Margin="5" 
                        Command="{Binding LoadClientsCommand}"
                        Background="#3498DB" Foreground="White" Cursor="Hand"/>
                <Button Content="Добавить" Width="100" Height="35" Margin="5" 
                        Command="{Binding AddClientCommand}"
                        Background="#27AE60" Foreground="White" Cursor="Hand"/>
                <Button Content="Редактировать" Width="100" Height="35" Margin="5" 
                        Command="{Binding UpdateClientCommand}" CommandParameter="{Binding SelectedClient}"
                        Background="#F39C12" Foreground="White" Cursor="Hand"/>
                <Button Content="Удалить" Width="100" Height="35" Margin="5" 
                        Command="{Binding DeleteClientCommand}" CommandParameter="{Binding SelectedClient}"
                        Background="#E74C3C" Foreground="White" Cursor="Hand"/>
                <Button Content="Сохранить" Width="100" Height="35" Margin="5" 
                        Command="{Binding SaveClientsCommand}"
                        Background="#1ABC9C" Foreground="White" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <ListView Grid.Row="1" ItemsSource="{Binding Clients}" SelectedItem="{Binding SelectedClient}"
                  Margin="0,0,0,10" Background="White" BorderBrush="#BDC3C7" BorderThickness="1">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID" Width="50" DisplayMemberBinding="{Binding Id}"/>
                    <GridViewColumn Header="ФИО" Width="150" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Компания" Width="180" DisplayMemberBinding="{Binding Company}"/>
                    <GridViewColumn Header="Телефон" Width="120" DisplayMemberBinding="{Binding Phone}"/>
                    <GridViewColumn Header="Email" Width="180" DisplayMemberBinding="{Binding Email}"/>
                    <GridViewColumn Header="Сделок" Width="80" DisplayMemberBinding="{Binding DealsCount}"/>
                    <GridViewColumn Header="Статус" Width="100" DisplayMemberBinding="{Binding Status}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Border Grid.Row="2" Background="#ECF0F1" Padding="10" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#2C3E50" FontSize="12"/>
                <ProgressBar x:Name="ProgressBar" Height="3" Margin="0,5,0,0" 
                             IsIndeterminate="{Binding IsBusy}" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>