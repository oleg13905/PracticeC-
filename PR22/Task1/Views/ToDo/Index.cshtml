@model IReadOnlyList<Task1.Models.ToDoItem>

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h2 class="h5 mb-0">Задачи (EF)</h2>
        <div class="text-muted small">Создание, отметка выполнения, удаление</div>
    </div>
    <a class="btn btn-primary" asp-controller="ToDo" asp-action="Create">+ Добавить</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-secondary mb-0">
        Пока нет задач. Добавьте первую.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead>
                <tr>
                    <th style="width: 1%;">Готово</th>
                    <th>Название</th>
                    <th style="width: 1%;">Дедлайн</th>
                    <th style="width: 1%;">Действия</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                var isOverdue = !item.IsCompleted && item.Deadline < DateOnly.FromDateTime(DateTime.Today);
                <tr class="@(item.IsCompleted ? "table-success" : (isOverdue ? "table-warning" : ""))">
                    <td class="text-center">
                        <form asp-controller="ToDo" asp-action="ToggleComplete" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <input class="form-check-input" type="checkbox" @(item.IsCompleted ? "checked" : "") onchange="this.form.submit()" />
                        </form>
                    </td>
                    <td>
                        <div class="fw-semibold">@item.Title</div>
                    </td>
                    <td class="text-nowrap">
                        <span class="@(isOverdue ? "fw-semibold text-danger" : "text-muted")">
                            @item.Deadline.ToString("yyyy-MM-dd")
                        </span>
                    </td>
                    <td class="text-nowrap">
                        <form asp-controller="ToDo" asp-action="Delete" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">Удалить</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

